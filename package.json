{
  "name": "gnosis-tms",
  "private": true,
  "version": "0.8.64",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test --import ./src-ui/test/register-raw-loader.mjs src-ui/app/*.test.js src-ui/screens/*.test.js",
    "test:browser": "playwright test",
    "audit:unused": "knip --no-progress",
    "icons:sync": "bash src-tauri/icons/sync-all-icons.sh",
    "tauri": "tauri",
    "typst:prepare": "node scripts/prepare-typst-sidecar.mjs",
    "tauri:dev": "npm run typst:prepare && tauri dev",
    "tauri:build": "npm run typst:prepare && tauri build",
    "prepare": "husky",
    "lint:rust:strict": "npm run typst:prepare && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "check:licenses:rust": "cargo deny --manifest-path src-tauri/Cargo.toml check licenses",
    "check:licenses:npm": "license-checker --production --excludePrivatePackages --onlyAllow \"MIT;Apache-2.0;Apache-2.0 WITH LLVM-exception;ISC;BSD-2-Clause;BSD-3-Clause;Zlib;Unicode-3.0;CC0-1.0;CDLA-Permissive-2.0;BSL-1.0;Unlicense;MIT-0;0BSD;MPL-2.0\"",
    "licenses:notices": "node scripts/generate-third-party-notices.mjs",
    "lint:js": "eslint \"src-ui/app/**/*.js\" \"src-ui/screens/**/*.js\"",
    "lint:js:fix": "eslint \"src-ui/app/**/*.js\" \"src-ui/screens/**/*.js\" --fix",
    "test:rust": "npm run typst:prepare && cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.5.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "license-checker": "^25.0.1",
    "vite": "^5.4.19"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "dependencies": {
    "@sentry/browser": "^10.56.0",
    "@tanstack/query-core": "^5.100.5",
    "@tanstack/virtual-core": "^3.14.0"
  }
}
