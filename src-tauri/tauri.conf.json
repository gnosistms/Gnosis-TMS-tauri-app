{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gnosis TMS",
  "version": "0.1.0",
  "identifier": "com.gnosis.tms",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1431",
    "devUrl": "http://127.0.0.1:1431",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Gnosis TMS",
        "width": 1400,
        "height": 820,
        "visible": true,
        "backgroundThrottling": "disabled",
        "resizable": true,
        "backgroundColor": "#F3D58A",
        "titleBarStyle": "Transparent"
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
